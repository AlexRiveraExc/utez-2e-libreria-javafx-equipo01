<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="utez.edu.mx.libreria.controller.PrincipalController"
            styleClass="root-pane">

    <!-- Cabecera -->
    <top>
        <VBox styleClass="header">
            <Label text="📚 Catálogo de la Biblioteca Escolar"
                   styleClass="header-title"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="txtBuscar"
                           promptText="Buscar por ISBN, título o autor…"
                           prefWidth="320" styleClass="search-field"
                           onKeyReleased="#onBuscar"/>
                <Button text="🔍 Buscar" onAction="#onBuscar"
                        styleClass="btn-secondary"/>
            </HBox>
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
        </VBox>
    </top>

    <!-- Tabla -->
    <center>
        <TableView fx:id="tablaLibros" styleClass="main-table">
            <columns>
                <TableColumn fx:id="colIsbn"       text="ISBN / ID"   prefWidth="140"/>
                <TableColumn fx:id="colTitulo"     text="Título"      prefWidth="210"/>
                <TableColumn fx:id="colAutor"      text="Autor"       prefWidth="160"/>
                <TableColumn fx:id="colAnio"       text="Año"         prefWidth="70"/>
                <TableColumn fx:id="colGenero"     text="Género"      prefWidth="120"/>
                <TableColumn fx:id="colDisponible" text="Disponible"  prefWidth="90"/>
            </columns>
            <placeholder>
                <Label text="No hay libros registrados aún."
                       styleClass="empty-label"/>
            </placeholder>
            <BorderPane.margin>
                <Insets top="8" right="16" bottom="8" left="16"/>
            </BorderPane.margin>
        </TableView>
    </center>

    <!-- Barra de botones -->
    <bottom>
        <HBox styleClass="bottom-bar" spacing="10" alignment="CENTER_LEFT">
            <Button text="➕ Nuevo"
                    onAction="#onNuevo"          styleClass="btn-primary"/>
            <Button text="✏ Editar"
                    onAction="#onEditar"         styleClass="btn-primary"/>
            <Button text="🗑 Eliminar"
                    onAction="#onEliminar"       styleClass="btn-danger"/>
            <Button text="🔎 Ver detalle"
                    onAction="#onVerDetalle"     styleClass="btn-secondary"/>
            <Button text="📄 Exportar reporte"
                    onAction="#onExportarReporte" styleClass="btn-accent"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblEstado" styleClass="status-label"/>
            <padding>
                <Insets top="10" right="16" bottom="10" left="16"/>
            </padding>
        </HBox>
    </bottom>
</BorderPane>